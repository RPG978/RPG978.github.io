<resources>

    <!-- Base App Theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary</item>
        <item name="colorAccent">@color/secondary</item>
    </style>

    <!-- Standard EditText Style -->
    <style name="EditTextStandard">
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:backgroundTint">@color/gray</item>
        <item name="android:textColorHint">#757575</item>
    </style>

    <!-- Primary Button Style -->
    <style name="PrimaryButton">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Secondary Button Style -->
    <style name="SecondaryButton">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
